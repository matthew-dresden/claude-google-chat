# Local .terraform directories (provider plugins, modules)
.terraform/
.terraform.tfstate.lock.info

# State files: contain real, environment-specific resource data and potential
# secrets. Never commit; use remote state (12-factor: config from the
# environment, environment-agnostic artifacts).
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files holding real (often sensitive) values. The committed
# terraform.tfvars.example is the template; real *.tfvars stay local.
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# CLI override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Note: .terraform.lock.hcl IS committed intentionally (provider dependency
# lock, analogous to uv.lock). Do not ignore it.
